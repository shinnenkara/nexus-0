{
  "name": "company-local-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Local guidance MCP server with canonical workflow/rule/skill registry.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "TSX_DISABLE_IPC=1 tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "prepare": "husky",
    "type:check": "tsc -p tsconfig.json --noEmit",
    "docs:generate": "npm run build --silent && node dist/scripts/generate-tool-docs.js",
    "toolset:generate": "npm run docs:generate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.3",
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
